<?xml version="1.0"?>

<robot name="test" xmlns:xacro="http://www.ros.org/wiki/xacro">
    <xacro:macro name="rgbaConv" params="name r g b a">
        <!-- converts input to standard 256 color code-->
        <material name="${name}">
            <color rgba="${r/255}
                         ${g/255}
                         ${b/255}
                         ${a}"/>
        </material>
    </xacro:macro>

    <xacro:macro name="wheel" params="prefix postfix reflect position">
        <!-- automatically creates wheels and axles. uses fixed values since base_link is fixed dimensions-->
        <link name="${prefix}_${postfix}_wheel">
            <visual>
            <geometry>
                <cylinder radius="0.05" length="0.045"/>
            </geometry>
            <origin xyz="0 0 0" rpy="${(90/180*pi)}
                                     ${(90/180*pi)}
                                     0"/>
            <xacro:rgbaConv name="black" r="0" g="0" b="0" a="1"/>
            </visual>
        </link>

        <link name="${prefix}_${postfix}_axle">
            <visual>
                <geometry>
                    <cylinder radius="0.025" length="0.02"/>
                </geometry>
                <origin xyz="0 0 0"
                        rpy="0 0 0"/>
                <xacro:rgbaConv name="grey" r="125" g="125" b="125" a="1"/>
            </visual>
        </link>

        <joint name="${prefix}_${postfix}_axle_joint" type="revolute">
            <parent link="base_link"/>
            <child link="${prefix}_${postfix}_axle"/>
            <origin xyz="${position*0.1} 
                         ${reflect*(0.255/2-0.05/2)} 
                         0.05"
                    rpy="0 0 0"/>
            <axis xyz="0 0 1"/>
            <limit lower="${-30/180*pi}" upper="${30/180*pi}" velocity="100" effort="100"/>
        </joint>

        <joint name="${prefix}_${postfix}_wheel_move" type="continuous">
            <parent link="${prefix}_${postfix}_axle"/>
            <child link="${prefix}_${postfix}_wheel"/>
            <axis xyz="0 1 0"/>
            <origin xyz="0 ${reflect*0.0025} 0" 
                    rpy="0 0 0"/>
        </joint>
    </xacro:macro>

    <link name="base_link">
        <visual>
            <geometry>
                <box size="0.33 0.255 0.22"/>
            </geometry>
            <origin xyz="0 0 ${0.22/2+0.024}" rpy="0 0 0"/>
            <xacro:rgbaConv name="blue" r="0" g="0" b="255" a="1"/>
        </visual>
    </link>

    <xacro:wheel prefix="left" postfix="front" reflect="1" position="1"/>
    <xacro:wheel prefix="right" postfix="front" reflect="-1" position="1"/>
    <xacro:wheel prefix="left" postfix="back" reflect="1" position="-1"/>
    <xacro:wheel prefix="right" postfix="back" reflect="-1" position="-1"/>
    
</robot>